    card.appendChild(span({style:{color:ppvStip===s.id?t.accent:'#aaa',fontSize:'10px',fontWeight:'700'}},s.label));
    card.addEventListener('click', () => { ppvStip=s.id; rebuild(); });
    stipGrid.appendChild(card);
  });
  stepSurf.appendChild(stipGrid);
}
wrap.appendChild(stepSurf);

// Action grid
const mob = isMobile();
if(mob){
  weekPlan.forEach(entry => {
    const w = STATE.roster.find(r=>r.id===entry.wid);
    if(!w) return;
    const c = rc(entry.role);
    const row = div({style:{marginBottom:'7px'}});
    const wrow = div({style:{background:t.surface,border:`1px solid ${c}18`,borderRadius:'8px',padding:'9px 11px',display:'flex',alignItems:'center',gap:'8px',marginBottom:'4px'}});
    wrow.appendChild(div({style:{width:'3px',height:'20px',borderRadius:'2px',background:c,flexShrink:'0'}}));
    const winfo = div({style:{flex:'1'}});
    winfo.appendChild(div({style:{color:'#ccc',fontFamily:t.font,fontSize:'12px',textTransform:'uppercase'}},w.short+(w.title?' 🏆':'')));
    wrow.appendChild(winfo);
    const roleRow = div({style:{display:'flex',gap:'2px'}});
    ['face','heel','tweener'].forEach(r => {
      const rb = btn({style:{padding:'2px 5px',fontSize:'7px',textTransform:'uppercase',background:entry.role===r?`${rc(r)}14`:'none',border:`1px solid ${entry.role===r?rc(r):t.border}`,color:entry.role===r?rc(r):'#2a2a3a',borderRadius:'3px'}},r);
      rb.addEventListener('click', () => {
        weekPlan = weekPlan.map(e=>e.wid===entry.wid?{...e,role:r}:e);
        STATE.roster = STATE.roster.map(wr=>wr.id===entry.wid?{...wr,role:r}:wr);
        rebuild();
      });
      roleRow.appendChild(rb);
    });
    wrow.appendChild(roleRow);
    row.appendChild(wrow);
    if(entry.action){
      const actRow = div({style:{background:`${c}0a`,border:`1.5px solid ${c}33`,borderRadius:'8px',padding:'9px 11px',display:'flex',gap:'8px',alignItems:'center',cursor:'pointer'}});
      actRow.appendChild(span({style:{fontSize:'14px'}},getActs(STATE.promo)[entry.action.cat]?.icon||''));
      const ainfo = div({style:{flex:'1'}});
