      clearBtn.addEventListener('click', e => { e.stopPropagation(); weekPlan=weekPlan.map(en=>en.wid===entry.wid?{...en,action:null}:en); rebuild(); });
      actRow.appendChild(clearBtn);
      row.appendChild(actRow);
    } else {
      const addBtn = btn({style:{width:'100%',padding:'10px',background:t.surface,border:`1px dashed ${t.border}`,borderRadius:'8px',color:'#2a2a3a',fontSize:'12px'}},'+ Ajouter une action');
      addBtn.addEventListener('click', () => showActionPicker(entry.wid));
      row.appendChild(addBtn);
    }
    wrap.appendChild(row);
  });
} else {
