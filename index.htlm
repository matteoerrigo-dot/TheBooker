  desc: champ
    ? `${champ.name}, champion ${champ.title}, exige d'être le main event de ${grandFinal} sans conditions. Il menace de no-show en cas de refus.`
    : `Le champion en titre exige une renégociation de son contrat en urgence — son avocat a envoyé une lettre.`,
  consequence: "Accorde ou prépare un tourney d'urgence." },

{ id:"mystery_attacker", icon:"🎭", sev:"warning",
  title: "ATTAQUANT MASQUÉ",
  desc: `Un mystérieux attaquant masqué frappe ${wmWinner?.name || randomW?.name} en coulisse. Aucune caméra n'a capté le visage. Les rumeurs vont bon train.`,
  consequence: "Révélation à planifier dans 2-3 semaines." },

{ id:"ppv_city_drama", icon:"🏙️", sev:"warning",
  title: isAEW ? "INCIDENT AU WEMBLEY" : "INCIDENT À VEGAS",
  desc: isAEW
    ? "La vente de billets pour All In au Wembley explose les records — mais les scalpers ont monopolisé les catégories VIP. Tollé médiatique."
    : "La ville hôte de WrestleMania menace d'annuler les autorisations suite à des incidents en dehors du ring. La pression sur la direction monte.",
  consequence: "La carte doit être irréprochable pour désamorcer." },

{ id:"ratings_crash", icon:"📉", sev:"critical",
  title: "CHUTE D'AUDIENCE",
  desc: `Le dernier ${show1} a enregistré son plus bas historique depuis 3 ans. ${isAEW ? "Tony Khan" : "La direction"} exige un shake-up immédiat de la carte.`,
  consequence: "Mets les plus gros noms en avant, cette semaine." },

{ id:"return_tease", icon:"⚡", sev:"opportunity",
  title: "TEASE DE RETOUR LÉGENDAIRE",
  desc: isAEW
    ? "Une silhouette non identifiée apparaît en fin de Dynamite. Les forums s'enflamment. Est-ce un retour légendaire pour All In ?"
    : "Une musique familière se déclenche en fin de Raw avant d'être coupée. La Twitterverse s'embrase. WrestleMania approche…",
  consequence: "Capitalise sur le buzz — révèle ou entretiens le mystère." },
```

];

// ── Pool contextuel (dépend du plan) ────────────────────────────────────
const contextPool = [];

if (wmWinner) {
contextPool.push(
{ id:`winner_promo_bomb_${wmWinner.id}`, icon:“🎤”, sev:“opportunity”,
title: `PROMO BOMBE DE ${wmWinner.name.toUpperCase()}`,
desc: `${wmWinner.name} lâche une promo d'anthologie sur ${show1} qui donne le ton pour ${grandFinal}. La foule est électrisée.`,
consequence: “Son momentum est au max — exploite-le.” },
{ id:`winner_doubt_${wmWinner.id}`, icon:“❓”, sev:“warning”,
title: `DOUTES SUR ${wmWinner.name.toUpperCase()}`,
desc: `${wmWinner.name} perd un match non-télévisé de façon embarrassante. Les doutes sur sa capacité à headliner ${grandFinal} refont surface.`,
consequence: “Une victoire propre cette semaine est indispensable.” }
);
}

if (wmRival) {
contextPool.push(
{ id:`rival_snaps_${wmRival.id}`, icon:“😤”, sev:“warning”,
title: `${wmRival.name.toUpperCase()} PÈTE UN CÂBLE`,
desc: `${wmRival.name} perd son sang-froid en coulisse et frappe un cadreur. ${isAEW ? "Tony Khan" : "La direction"} envisage une suspension.`,
consequence: “Son match à ${grandFinal} est en suspens.” },
{ id:`rival_ally_${wmRival.id}`, icon:“🤝”, sev:“warning”,
title: `${wmRival.name.toUpperCase()} RECRUTE`,
desc: `${wmRival.name} approche ${r2?.name || "un inconnu"} pour l'aider à neutraliser ${wmWinner?.name || "son rival"}. L'alliance est en train de se former.`,
consequence: “Le 1v1 de ${grandFinal} devient plus compliqué.” }
);
}

if (injured.length) {
const inj = pick(injured);
contextPool.push(
{ id:`return_${inj.id}`, icon:“⚡”, sev:“opportunity”,
title: `RETOUR SURPRISE : ${inj.name.toUpperCase()}`,
desc: `${inj.name} revient plus tôt que prévu — il est guéri à 80% mais veut absolument être là pour ${grandFinal}. Les médecins ne sont pas d'accord.`,
consequence: “À toi de décider : retour immédiat ou encore 2 semaines ?” }
);
}

if (r1) {
contextPool.push(
{ id:`breakout_${r1.id}`, icon:“📈”, sev:“opportunity”,
title: `BREAKOUT : ${r1.name.toUpperCase()}`,
desc: `${r1.name} vole la vedette sur ${show2} avec une performance de 20 minutes. Les fans votent massivement pour lui en ligne. Il est prêt pour le grand saut.`,
consequence: “Push ou jalousie du vestiaire — à toi de choisir.” }
);
}

if (isAEW) {
contextPool.push(
{ id:“njpw_drama”, icon:“🌏”, sev:“warning”,
title: “TENSION FORBIDDEN DOOR”,
desc: `Un talent NJPW prévu pour Forbidden Door refuse les conditions contractuelles AEW. L'accord entre les deux fédérations est fragilisé.`,
consequence: “Le cross-over doit être reconfirmé ou remplacé.” },
{ id:“elite_reunion”, icon:“🖐️”, sev:“opportunity”,
title: “RÉUNION ELITE ?”,
desc: `Des rumeurs de réunion de l'Elite complète circulent — les fans sont en ébullition sur Twitter. Tony Khan alimente le mystère.`,
consequence: “Confirme ou démente — les deux créent du buzz.” }
);
} else {
contextPool.push(
{ id:“wwe_hall_tease”, icon:“🏛️”, sev:“opportunity”,
title: “TEASE HALL OF FAME”,
desc: `Une annonce Hall of Fame surprise est prévue pour WrestleMania Week — une légende va faire son retour dans l'arène. Les paris vont bon train.`,
consequence: “Intègre une interaction avec un acteur de ta carte.” },
{ id:“draft_rumor”, icon:“📋”, sev:“warning”,
title: “RUMEURS DE DRAFT”,
desc: `Des rumeurs de Draft surprise avant WrestleMania circulent — ${randomW?.name} serait transféré. Plusieurs contrats sont en renégociation.`,
consequence: “Planifie les arcs en tenant compte des incertitudes.” }
);
}

// ── Merge tous les pools et filtrer déjà vus ────────────────────────────
const allPool = […universalPool, …contextPool];
const fresh = allPool.filter(e => !CRISIS_HISTORY.has(e.id));
const pool = fresh.length > 0 ? fresh : allPool; // reset si tout vu

if (!pool.length) return null;
const chosen = pick(pool);
CRISIS_HISTORY.add(chosen.id);
return chosen;
}

function scoreBooking(actions, roster, difficulty=“normal”){
if(!actions||actions.length===0) return difficulty===“hard”?1:1.5;
const H=difficulty===“hard”; // shorthand

let score=0;
let total=0;
const usedCats=new Set();
const usedActionIds=new Set();
const usedWids=new Set();
let incoherenceCount=0;
let repeatPenalty=0;

for(const entry of actions){
const w=roster.find(r=>r.id===entry.wid);
if(!w) continue;
total++;
usedWids.add(entry.wid);
const a=entry.action;
if(!a) continue;

```
// Actions répétées
if(usedActionIds.has(a.id)) repeatPenalty+=H?2.5:1.5;
usedActionIds.add(a.id);
usedCats.add(entry.cat);

// Base — HARD compresse davantage
let base=H?(a.mom*0.55+a.heat*0.45)/2:(a.mom*0.7+a.heat*0.3)/2;

// Cohérence rôle/action
const isHeel=entry.role==="heel";
const isTweener=entry.role==="tweener";
const isHeelAct=["ph","mh","sh","ch"].some(p=>a.id?.startsWith(p));
const isFaceAct=["pf","mf","sf","cf"].some(p=>a.id?.startsWith(p));

if(isHeel&&isHeelAct)                    base*=H?1.25:1.3;
else if(!isHeel&&!isTweener&&isFaceAct)  base*=H?1.25:1.3;
else if(isTweener)                        base*=H?0.85:0.95;
else { base*=H?0.40:0.60; incoherenceCount++; }

// Tier
if(w.tier==="main-event") base*=H?1.12:1.2;
else if(w.tier==="rising") base*=H?1.04:1.1;

// Stats superstar
const popBonus=w.pop>=90?(H?1.2:1.5):w.pop>=80?(H?0.6:1.0):w.pop>=70?(H?0.2:0.4):(H?-0.3:0);
const momBonus=w.mom>=90?(H?1.2:1.5):w.mom>=80?(H?0.6:1.0):w.mom>=70?(H?0.2:0.4):(H?-0.8:-0.3);
base+=popBonus+momBonus;

// Feud
if(w.feuds&&w.feuds.length>0) base*=H?1.08:1.12;
else base*=H?0.88:0.94;

// Blessé
if(w.status==="injured") base*=0.2;

score+=base;
```

}

if(total===0) return H?1:1.5;

score-=repeatPenalty;
score-=incoherenceCount*(H?3.5:2);

// Variété catégories — HARD exige 3+ pour passer au-dessus de 3★
if(usedCats.size===1)      score*=H?0.45:0.60;
else if(usedCats.size===2) score*=H?0.72:0.85;
else if(usedCats.size===3) score*=H?1.08:1.12;
else if(usedCats.size>=4)  score*=H?1.20:1.25;

// One-man show
if(usedWids.size===1&&total>1) score*=H?0.65:0.78;

const raw=score/total;

// NORMAL : seuils plus généreux — 3★ accessible, 5★ demande de l’effort
// HARD   : seuils très resserrés — 5★ quasi-impossible sans tout aligner
let normalized;
if(H){
if(raw<1.5)      normalized=1;
else if(raw<3)   normalized=1+(raw-1.5)/1.5*1;
else if(raw<4.5) normalized=2+(raw-3)/1.5*1;
else if(raw<6)   normalized=3+(raw-4.5)/1.5*1;
else if(raw<7.5) normalized=4+(raw-6)/1.5*0.5;
else             normalized=4.5+(raw-7.5)/3*0.5;
} else {
if(raw<2)        normalized=1;
else if(raw<3.5) normalized=1.5+(raw-2)/1.5*0.5;
else if(raw<5)   normalized=2+(raw-3.5)/1.5*1;
else if(raw<6.5) normalized=3+(raw-5)/1.5*1;
else if(raw<8)   normalized=4+(raw-6.5)/1.5*0.5;
else             normalized=4.5+(raw-8)/2*0.5;
}

normalized=Math.max(1,Math.min(5,normalized));
return Math.round(normalized*2)/2;
}
function buildWrestlerNotes(actions, roster){
const notes={};
for(const entry of actions){
const w=roster.find(r=>r.id===entry.wid);
if(!w||!entry.action)continue;
const isCoherent=(entry.role===“heel”&&[“ph”,“mh”,“sh”,“ch”].some(p=>entry.action.id?.startsWith(p)))||
(entry.role===“face”&&[“pf”,“mf”,“sf”,“cf”].some(p=>entry.action.id?.startsWith(p)));
notes[entry.wid]=isCoherent
?`\${w.name} bien utilisé — action cohérente avec son rôle.`
:`\${w.name} — attention à la cohérence rôle/action.`;
}
return notes;
}

function buildCrowdResult(stars, actions, roster){
const noise=Math.min(5,Math.max(1,Math.round(stars)));
const mainAct=actions?.filter(e=>e.action)?.[0];
const mainW=mainAct?roster.find(r=>r.id===mainAct?.wid):null;

let chantPool, reactionPool, voicePool, notePool, verdict;
if(stars>=4.5){chantPool=CHANTS_HOT;reactionPool=REACTIONS_5;voicePool=VOICES_5;notePool=NOTES_5;verdict=“OVATION DEBOUT”;}
else if(stars>=3.5){chantPool=CHANTS_WARM;reactionPool=REACTIONS_4;voicePool=VOICES_4;notePool=NOTES_4;verdict=“CHAUD”;}
else if(stars>=2.5){chantPool=CHANTS_WARM;reactionPool=REACTIONS_3;voicePool=VOICES_3;notePool=NOTES_3;verdict=“TIÈDE”;}
else if(stars>=1.5){chantPool=CHANTS_COLD;reactionPool=REACTIONS_2;voicePool=VOICES_2;notePool=NOTES_2;verdict=“HEAT NÉGATIF”;}
else{chantPool=CHANTS_COLD;reactionPool=REACTIONS_1;voicePool=VOICES_1;notePool=NOTES_1;verdict=“SILENCE GÊNANT”;}

// Heel actions can flip chant to heat chant
const hasHeatAction=actions?.some(e=>[“ph2”,“mh4”,“sh2”,“sh3”].includes(e.action?.id));
if(hasHeatAction&&stars>=3) chantPool=CHANTS_HEAT;

const chant=fmtChant(pick(chantPool),mainW?.name);
const highlights=pickN(HIGHLIGHTS_POOL,Math.min(3,Math.ceil(stars)));
const mistakes=stars<3.5?pickN(MISTAKES_POOL,Math.min(2,Math.floor(3.5-stars)+1)):[];

return{
stars,noise,chant,
reaction:pick(reactionPool),
voice:pick(voicePool),
highlights,mistakes,
note:pick(notePool),
verdict,
wrestler_notes:buildWrestlerNotes(actions||[],roster),
};
}

// Wrapper async pour garder la même signature qu’avant
async function callCrowd(prompt, roster, actionsData=[], difficulty=“normal”){
await new Promise(r=>setTimeout(r,600+Math.random()*800));
const stars=scoreBooking(actionsData,roster,difficulty);
return buildCrowdResult(stars,actionsData,roster);
}

async function generateRoadPlan(roster){
await new Promise(r=>setTimeout(r,800));
const mainEvent=roster.filter(w=>w.tier===“main-event”&&w.status===“active”);
const rising=roster.filter(w=>w.tier===“rising”&&w.status===“active”);
const heels=mainEvent.filter(w=>w.role===“heel”);
const faces=mainEvent.filter(w=>w.role===“face”||w.role===“tweener”);
const champions=roster.filter(w=>w.title&&w.status===“active”);

const wmWinner=pick(faces.length?faces:mainEvent);
const wmRival=pick(heels.filter(h=>h.id!==wmWinner.id).length?heels.filter(h=>h.id!==wmWinner.id):mainEvent.filter(w=>w.id!==wmWinner.id));

// Le vainqueur du Rumble = celui qui va à WM (peut être différent du winner final)
const rumbleWinner=wmWinner;
// Le survivor de la Chamber = le challenger désigné
const chamberPool=mainEvent.filter(w=>w.id!==wmWinner.id&&w.id!==wmRival?.id);
const chamberSurvivor=chamberPool.length?pick(chamberPool):wmRival;
// Champion en titre
const champion=champions.length?pick(champions):null;

const chaos=pick(roster.filter(w=>w.status===“active”&&w.id!==wmWinner.id));

const ARCS=[
`\${wmWinner.name} cherche à prouver qu'il est le meilleur, \${wmRival?.name} fait tout pour l'en empêcher.`,
`La rivalité entre \${wmWinner.name} et \${wmRival?.name} atteint son point de rupture.`,
`\${wmWinner.name} doit surmonter la trahison de \${wmRival?.name} pour atteindre le sommet.`,
`Deux visions s'affrontent : l'honneur de \${wmWinner.name} contre la domination de \${wmRival?.name}.`,
];

return{
winner:wmWinner.id,
winnerId:wmWinner.id,
winnerName:wmWinner.name,
rivalId:wmRival?.id,
rivalName:wmRival?.name,
rumbleWinnerId:rumbleWinner.id,
rumbleWinnerName:rumbleWinner.name,
chamberSurvivorId:chamberSurvivor?.id,
chamberSurvivorName:chamberSurvivor?.name,
championId:champion?.id,
championName:champion?.name,
championTitle:champion?.title,
finalMatch:`\${wmWinner.name} vs \${wmRival?.name}`,
card:[
`\${wmWinner.name} vs \${wmRival?.name} (Main Event WM)`,
`\${pick(rising)?.name||"Rising Star"} vs \${pick(chamberPool)?.name||"Challenger"}`,
],
feuds:[{wrestlers:`\${wmWinner.name} & \${wmRival?.name}`,arc:pick(ARCS)}],
narrative:pick(ARCS),
chaos:{who:chaos.id,what:`\${chaos.name} perturbe le plan principal.`,impact:“Le booking doit être repensé.”},
};
}

