function pick(arr){return arr[Math.floor(Math.random()*arr.length)];}
function pickN(arr,n){const s=[…arr];const r=[];while(r.length<n&&s.length){const i=Math.floor(Math.random()*s.length);r.push(s.splice(i,1)[0]);}return r;}
function fmtChant(c,name){return c.replace(/{NAME}/g,(name||’’).split(’ ‘)[0].toUpperCase()||“LET’S GO”);}

// ─── CRISIS ENGINE v2 ─────────────────────────────────────────────────────────
const CRISIS_HISTORY = new Set(); // track seen crisis IDs this session

function buildCrisisEvent(stepId, roster, plan, promo=“WWE”){
const isAEW = promo === “AEW”;
const grandFinal = isAEW ? “All In” : “WrestleMania”;
const show1 = isAEW ? “Dynamite” : “Raw”;
const show2 = isAEW ? “Collision” : “SmackDown”;

const act    = roster.filter(w => w.status === “active”);
const injured = roster.filter(w => w.status === “injured”);
if (!act.length) return null;

const champions = act.filter(w => w.title);
const mainEvent = act.filter(w => w.tier === “main-event”);
const rising    = act.filter(w => w.tier === “rising”);
const heels     = act.filter(w => w.role === “heel”);
const faces     = act.filter(w => w.role === “face”);

const wmWinner = plan?.winnerId   ? act.find(w => w.id === plan.winnerId)   : pick(mainEvent);
const wmRival  = plan?.rivalId    ? act.find(w => w.id === plan.rivalId)    : pick(heels);
const champ    = plan?.championId ? roster.find(w => w.id === plan.championId) : champions[0];

const r1 = pick(rising) || pick(act);
const r2 = pick(rising.filter(w => w.id !== r1?.id)) || pick(act.filter(w => w.id !== r1?.id));
const randomW = pick(act);
const randomHeel = pick(heels) || pick(act);
const randomFace = pick(faces) || pick(act);

// ── Pool universel (toujours disponible) ─────────────────────────────────
const universalPool = [
{ id:“gm_fired”, icon:“💼”, sev:“critical”,
title: isAEW ? “TONY KHAN SOUS PRESSION” : “LE GM VIRÉ EN DIRECT”,
desc: isAEW
? `Tony Khan annonce en direct sur ${show1} qu'il prend le contrôle opérationnel du booking à la suite de résultats décevants. Les vestiaires sont en ébullition.`
: `Le GM de ${show1} est licencié sans préavis. Un intérimaire est nommé pour la semaine — personne ne sait qui a le pouvoir.`,
consequence: “Tous les matchs prévus sont à rebooker.” },

```
