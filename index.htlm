}

// ── Step 2: Result ──
function buildStep2(){
const frag = div({});
frag.appendChild(mkCrowdResult(result, t));
frag.appendChild(div({style:{marginTop:‘14px’}}));
frag.lastChild.appendChild(mkBtn(‘🔁 Nouvelle storyline’, () => {
step=0; selected=[]; stip=null; winner=null; titleChange=null;
matchFormat={format:‘singles’,participants:[],winnerId:null};
weeks=[{},{},{},{}]; result=null; loading=false;
rebuild();
}, {t, full:true}));
return frag;
}

// ── Wrestler accordion ──
function buildWrestlerAccordion(w){
let open = false;
const c = rc(w.role);
const container = div({style:{marginBottom:‘7px’}});

```
function rebuildAcc(){
  container.innerHTML = '';
  const header = div({style:{
    background:t.surface, border:`1px solid ${c}22`,
    borderRadius: open?'10px 10px 0 0':'10px', padding:'10px 12px',
    display:'flex', alignItems:'center', gap:'10px', cursor:'pointer'
  }});
  header.appendChild(div({style:{width:'3px',height:'28px',borderRadius:'2px',background:c,flexShrink:'0'}}));
  const info = div({style:{flex:'1'}});
  info.appendChild(div({style:{color:'#ddd',fontFamily:t.font,fontSize:'13px',textTransform:'uppercase',letterSpacing:'1px'}},w.short+(w.title?' 🏆':'')+(w.status==='injured'?' 🚑':'')));
  const bars = div({style:{display:'flex',gap:'4px',marginTop:'4px'}});
  bars.appendChild(mkMiniBar('MOM',w.mom,t.accent));
  bars.appendChild(mkMiniBar('POP',w.pop,'#00e5aa'));
  info.appendChild(bars);
  header.appendChild(info);
  const filledCount = weeks.filter(wk => wk[w.id]).length;
  if(filledCount>0){
    const badge = div({style:{background:`${c}18`,border:`1px solid ${c}44`,borderRadius:'10px',padding:'2px 7px',color:c,fontSize:'10px',fontWeight:'700'}},`${filledCount}✓`);
    header.appendChild(badge);
  }
  header.appendChild(span({style:{color:'#333',fontSize:'14px',transform:open?'rotate(180deg)':'none',transition:'transform .2s'}}, open?'▴':'▾'));
  header.addEventListener('click', () => { open=!open; rebuildAcc(); });
  container.appendChild(header);

  if(open){
    const body = div({style:{background:t.surface,border:`1px solid ${c}22`,borderTop:'none',borderRadius:'0 0 10px 10px',padding:'10px 12px'}});
    // Role selector
    const roles = div({style:{display:'flex',gap:'4px',marginBottom:'10px'}});
    ['face','heel','tweener'].forEach(r => {
      const rb = btn({style:{
        flex:'1', padding:'5px 0', fontSize:'8px', textTransform:'uppercase',
        background:w.role===r?`${rc(r)}14`:'none',
        border:`1px solid ${w.role===r?rc(r):t.border}`,
        color:w.role===r?rc(r):'#333', borderRadius:'4px', fontFamily:t.font
      }}, r);
      rb.addEventListener('click', () => {
        STATE.roster = STATE.roster.map(wr => wr.id===w.id ? {...wr, role:r} : wr);
        w = STATE.roster.find(wr=>wr.id===w.id);
        rebuildAcc();
      });
      roles.appendChild(rb);
    });
    body.appendChild(roles);
    // Week slots
    weeks.forEach((wk, wi) => {
      const act = wk[w.id];
      const slotLabel = div({style:{color:'#333',fontSize:'8px',letterSpacing:'2px',marginBottom:'4px',fontFamily:t.font}},`SEMAINE ${wi+1}`);
      body.appendChild(slotLabel);
      if(act){
        const actRow = div({style:{background:`${c}0a`,border:`1.5px solid ${c}33`,borderRadius:'8px',padding:'8px 10px',display:'flex',gap:'8px',alignItems:'center',marginBottom:'8px'}});
        actRow.appendChild(span({style:{fontSize:'14px'}},getActs(STATE.promo)[act.cat]?.icon||''));
        const actInfo = div({style:{flex:'1'}});
        actInfo.appendChild(div({style:{color:c,fontSize:'11px',fontWeight:'700'}},act.action.label));
        if(act.action.desc) actInfo.appendChild(div({style:{color:'#444',fontSize:'9px'}},act.action.desc));
        actRow.appendChild(actInfo);
        const clearBtn = btn({style:{background:'none',border:`1px solid ${t.border}`,color:'#555',width:'22px',height:'22px',borderRadius:'4px',fontSize:'10px',flexShrink:'0'}},'×');
        clearBtn.addEventListener('click', () => {
          const newWks = weeks.map((w2,i) => { if(i!==wi) return w2; const n={...w2}; delete n[w.id]; return n; });
          weeks = newWks; rebuildAcc();
        });
        actRow.appendChild(clearBtn);
        body.appendChild(actRow);
      } else {
        const addBtn = btn({style:{width:'100%',padding:'10px',background:'#ffffff03',border:`1px dashed ${t.border}`,borderRadius:'8px',color:'#2a2a3a',fontSize:'12px',marginBottom:'8px'}},`+ Action semaine ${wi+1}`);
        addBtn.addEventListener('click', () => {
          showActionPicker(w, wi);
        });
        body.appendChild(addBtn);
      }
    });
    container.appendChild(body);
  }
}
rebuildAcc();
return container;
```

}

// ── Action picker modal ──
let currentPickerOverlay = null;
function showActionPicker(w, wi){
if(currentPickerOverlay) currentPickerOverlay.remove();
const content = mkActionPicker(w, w.role, (cat, action) => {
weeks = weeks.map((wk,i) => i!==wi ? wk : {…wk, [w.id]:{cat, action}});
closeActionPicker();
rebuild();
}, closeActionPicker, t, STATE.promo);
currentPickerOverlay = mkSheet(null, content, closeActionPicker, t);
// Override sheet style for action picker
currentPickerOverlay.style.zIndex = ‘300’;
document.body.appendChild(currentPickerOverlay);
}
function closeActionPicker(){
if(currentPickerOverlay){ currentPickerOverlay.remove(); currentPickerOverlay=null; }
}

// ── Match format panel ──
function buildMatchFormatPanel(selW){
const surf = mkSurface(t, {marginBottom:‘10px’});
surf.appendChild(mkLabel(‘Format du match PPV’, t.accent));
const fmtGrid = div({cls:‘flex-wrap’, style:{marginBottom:‘12px’}});
MATCH_FORMATS.forEach(f => {
const isSel = matchFormat.format === f.id;
const card = div({style:{
background:isSel?`${t.accent}18`:t.surface, border:`1.5px solid ${isSel?t.accent:t.border}`,
borderRadius:‘8px’, padding:‘7px 11px’, cursor:‘pointer’,
display:‘flex’, alignItems:‘center’, gap:‘6px’, transition:‘all .12s’
}});
card.appendChild(span({style:{fontSize:‘14px’}},f.icon));
const info = div({});
info.appendChild(div({style:{color:isSel?t.accent:’#bbb’,fontFamily:t.font,fontSize:‘10px’,fontWeight:‘700’,letterSpacing:‘1px’,textTransform:‘uppercase’}},f.label));
info.appendChild(div({style:{color:’#333’,fontSize:‘8px’}},`${f.n} participants`));
card.appendChild(info);
if(isSel) card.appendChild(span({style:{color:t.accent,fontSize:‘10px’}},‘✓’));
card.addEventListener(‘click’, () => {
matchFormat = {format:f.id, participants:matchFormat.participants.slice(0,f.n), winnerId:null};
rebuild();
});
fmtGrid.appendChild(card);
});
surf.appendChild(fmtGrid);
return surf;
}

// ── Title change panel ──
function buildTitleChangePanel(){
const surf = mkSurface(t, {marginBottom:‘10px’});
const enabled = titleChange !== null;
const champions = roster.filter(w=>w.title&&w.status===‘active’);
const row = div({style:{display:‘flex’,alignItems:‘center’,justifyContent:‘space-between’,marginBottom:enabled?‘10px’:‘0’}});
const left = div({style:{display:‘flex’,alignItems:‘center’,gap:‘8px’}});
left.appendChild(span({style:{fontSize:‘18px’}},‘🏆’));
const linfo = div({});
linfo.appendChild(div({style:{color:t.alt,fontFamily:t.font,fontSize:‘11px’,letterSpacing:‘2px’,textTransform:‘uppercase’}},‘Changement de titre’));
linfo.appendChild(div({style:{color:’#444’,fontSize:‘10px’}},‘Un titre change de mains au PPV ?’));
left.appendChild(linfo);
row.appendChild(left);
const toggleBtn = btn({style:{
background:enabled?`${t.alt}18`:‘none’, border:`1.5px solid ${enabled?t.alt:t.border}`,
color:enabled?t.alt:’#444’, borderRadius:‘20px’, padding:‘5px 14px’,
fontSize:‘11px’, fontFamily:t.font, letterSpacing:‘1px’, fontWeight:‘700’, transition:‘all .15s’
}}, enabled?‘OUI’:‘NON’);
toggleBtn.addEventListener(‘click’, () => {
titleChange = enabled ? null : {fromId:champions[0]?.id||null, toId:null};
rebuild();
});
row.appendChild(toggleBtn);
surf.appendChild(row);
return surf;
}

// ── Submit ──
async function doSubmit(){
if(loading) return;
loading = true; rebuild();
const fmtBonus = matchFormat.format===‘fatal4’?4:matchFormat.format===‘triple’?2:matchFormat.format===‘gauntlet’?5:matchFormat.format===‘elimination’?6:0;
const selW = roster.filter(w=>selected.includes(w.id));
const actionsData = selW.flatMap(w =>
[0,1,2,3].map(wi => {
const a = weeks[wi]?.[w.id];
return a ? {wid:w.id,cat:a.cat,action:{…a.action,mom:(a.action.mom||0)+fmtBonus},role:w.role} : null;
}).filter(Boolean)
);
const r = await callCrowd(’’, roster, actionsData, STATE.difficulty);
result = r;
if(titleChange?.fromId && titleChange?.toId){
STATE.roster = applyTitleChange(STATE.roster, titleChange);
}
STATE.globalStars.push(r.stars);
step = 2; loading = false;
rebuild();
}

return mkPageWrap(t, buildUI());
}

// ═══════════════════════════════════════════════════════
// SCREEN: ROAD TO PPV
// ═══════════════════════════════════════════════════════
function screenRoad(){
const t = getT();
const road = ROAD[STATE.promo];
const finalPPV = road[road.length-1]?.label || ‘Grand PPV’;

let phase = ‘intro’; // intro | gen | active | final
let plan = null;
let step = 0;
let weekResults = [];
let allResults = [];
let lastResult = null;
let crisis = null;
let loading = false;
let ppvStip = null;
let titleChange = null;
let matchFormat = {format:‘singles’,participants:[],winnerId:null};
let weekPlan = [];
let showPlan = false;

function initWeekPlan(){
weekPlan = STATE.roster.filter(w=>w.status===‘active’).map(w=>({wid:w.id,role:w.role,action:null}));
}
initWeekPlan();

function goHome(){ render(screenHome()); }

function maybeCrisis(s){
const stepId = road[s]?.id;
if(Math.random() < (road[s]?.type===‘ppv’?.70:.40)){
const ev = buildCrisisEvent(stepId, STATE.roster, plan, STATE.promo);
if(ev){ crisis = ev; rebuild(); }
}
}

async function doStart(){
phase = ‘gen’; rebuild();
const p = await generateRoadPlan(STATE.roster);
if(p?.chaos?.who){
STATE.roster = STATE.roster.map(w => w.id===p.chaos.who ? {…w,status:‘injured’,mom:clamp(w.mom-20)} : w);
}
plan = p || {narrative:‘La route commence.’,chaos:{what:‘Blessure inattendue.’,impact:‘À rebooker.’},card:[],feuds:[]};
phase = ‘active’; step = 0; initWeekPlan(); rebuild();
setTimeout(()=>maybeCrisis(0), 300);
}

async function doSubmitWeek(){
if(loading) return;
loading = true; rebuild();
const s = road[step];
const fmtBonus = matchFormat.format===‘fatal4’?4:matchFormat.format===‘triple’?2:matchFormat.format===‘gauntlet’?5:matchFormat.format===‘elimination’?6:0;
const actionsData = weekPlan.filter(e=>e.action).map(e=>({
wid:e.wid, cat:e.action.cat,
action:{…e.action.action, mom:(e.action.action.mom||0)+fmtBonus},
role:e.role
}));
if(s.type===‘ppv’ && ppvStip){
actionsData.forEach(a=>{ a.action={…a.action,mom:(a.action.mom||0)+3,heat:(a.action.heat||0)+3}; });
}
const r = await callCrowd(’’, STATE.roster, actionsData, STATE.difficulty);
const fmtD = MATCH_FORMATS.find(f=>f.id===matchFormat.format)||MATCH_FORMATS[0];
const enriched = {…r, _label:s.label, stepId:s.id, matchFormat:fmtD.label};
// Apply crisis effects
if(crisis){
if(crisis.wrestler && [‘injury’,‘walkout’,‘rumble_chaos’,‘title_vacated’,‘wm_threat’,‘injury_surprise’].some(x=>crisis.id.includes(x)||crisis.id===x)){
STATE.roster = STATE.roster.map(w => w.id===crisis.wrestler.id ? {…w,status:‘injured’} : w);
}
if(crisis.wrestler && [‘return’,‘pop’,‘heat’].some(x=>crisis.id.includes(x))){
STATE.roster = STATE.roster.map(w => w.id===crisis.wrestler.id ? {…w,status:‘active’,mom:clamp(w.mom+15)} : w);
}
}
// Apply momentum + title change
STATE.roster = STATE.roster.map(w => {
const e = weekPlan.find(p=>p.wid===w.id);
if(!e?.action) return w;
return {…w, mom:clamp(w.mom + Math.round(e.action.action.mom/2))};
});
STATE.roster = applyTitleChange(STATE.roster, titleChange);
weekResults.push(enriched); allResults.push(enriched);
STATE.globalStars.push(r.stars);
lastResult = enriched; crisis = null; ppvStip = null; titleChange = null;
matchFormat = {format:‘singles’,participants:[],winnerId:null};
const next = step + 1;
if(next >= road.length){ phase=‘final’; loading=false; rebuild(); }
else {
step = next; initWeekPlan(); loading=false; rebuild();
setTimeout(()=>maybeCrisis(next), 200);
}
}

function doRestart(){
phase=‘intro’; weekResults=[]; step=0; plan=null; crisis=null;
allResults=[]; lastResult=null; ppvStip=null;
matchFormat={format:‘singles’,participants:[],winnerId:null};
initWeekPlan(); rebuild();
}

// ── Action picker for road mode ──
let currentPickerOverlay = null;
function showActionPicker(wid){
if(currentPickerOverlay) currentPickerOverlay.remove();
const w = STATE.roster.find(r=>r.id===wid);
const entry = weekPlan.find(e=>e.wid===wid);
if(!w||!entry) return;
const content = mkActionPicker(w, entry.role, (cat, action) => {
weekPlan = weekPlan.map(e => e.wid===wid ? {…e, action:{cat,action}} : e);
closeActionPicker(); rebuild();
}, closeActionPicker, t, STATE.promo);
currentPickerOverlay = mkSheet(null, content, closeActionPicker, t);
currentPickerOverlay.style.zIndex = ‘300’;
document.body.appendChild(currentPickerOverlay);
}
function closeActionPicker(){ if(currentPickerOverlay){currentPickerOverlay.remove();currentPickerOverlay=null;} }

function rebuild(){
render(mkPageWrap(t, buildUI()));
}

function buildUI(){
const wrap = div({style:{maxWidth:‘1100px’,margin:‘0 auto’,padding:‘20px 14px 100px’}});

```
if(phase === 'intro') return buildIntro();
if(phase === 'gen') return buildGen();
if(phase === 'final') return buildFinal();

// Active phase
const avg = weekResults.length ? (weekResults.reduce((s,r)=>s+r.stars,0)/weekResults.length).toFixed(1) : '—';
const extras = [
  mkBtn(showPlan?'Cacher':'Plan IA', () => {showPlan=!showPlan;rebuild();}, {t, variant:'ghost', small:true}),
];
if(weekResults.length){
  const avgBadge = div({style:{background:`${t.alt}12`,border:`1px solid ${t.alt}33`,borderRadius:'6px',padding:'4px 9px',display:'flex',gap:'4px',alignItems:'center'}});
  avgBadge.appendChild(mkStars(parseFloat(avg)||0,10,t.alt));
  avgBadge.appendChild(span({style:{color:t.alt,fontFamily:t.font,fontSize:'13px'}},avg));
  extras.push(avgBadge);
}
wrap.appendChild(mkNavBar(`🎲 Road to ${finalPPV}`, goHome, t, extras));

// Timeline
const timelineWrap = div({cls:'timeline-wrap'});
const timeline = div({cls:'timeline'});
road.forEach((s,i) => {
  const done = i<step, isCur = i===step, isPpv = s.type==='ppv';
  const res = weekResults.find(r=>r.stepId===s.id);
  const bc = isCur?t.accent:done?(res?.stars>=4?'#00e5aa':res?.stars>=3?'#f5c518':'#ff2244'):'#111';
  const cell = div({style:{display:'flex',flexDirection:'column',alignItems:'center',gap:'2px',minWidth:isPpv?'68px':'40px'}});
  const box = div({style:{
    width:'100%', height:isPpv?'24px':'20px', borderRadius:'4px',
    background:isCur?`${t.accent}14`:done?`${bc}12`:'#ffffff03',
    border:`1.5px solid ${bc}`, display:'flex',alignItems:'center',justifyContent:'center',transition:'all .3s'
  }});
  if(done&&res) box.appendChild(span({style:{fontSize:'8px',color:bc,fontFamily:t.font}},`${res.stars}★`));
  else if(isCur) box.appendChild(span({style:{color:t.accent,fontSize:'9px',animation:'pulse .7s infinite alternate'}},'▶'));
  else box.appendChild(span({style:{color:'#1a1a1a',fontSize:'7px',fontFamily:t.font}},isPpv?'PPV':'—'));
  cell.appendChild(box);
  cell.appendChild(div({style:{color:isCur?t.accent:done?'#444':'#1a1a1a',fontSize:'6px',textAlign:'center',fontFamily:t.font,lineHeight:'1.2',maxWidth:isPpv?'68px':'40px'}},s.label||''));
  timeline.appendChild(cell);
});
timelineWrap.appendChild(timeline);
wrap.appendChild(timelineWrap);

// Plan reveal
if(showPlan && plan){
  const planSurf = mkSurface(t, {marginBottom:'12px',borderColor:`${t.accent}33`,animation:'slideUp .3s ease'});
  planSurf.appendChild(mkLabel('🤖 Plan IA (secret)', t.accent));
  planSurf.appendChild(div({style:{color:'#666',fontSize:'12px',lineHeight:'1.7',marginBottom:'8px'}},plan.narrative));
  const chaosBox = div({style:{background:'#ff224408',border:'1px solid #ff224418',borderRadius:'8px',padding:'10px'}});
  chaosBox.appendChild(mkLabel('💥 Crise initiale','#ff2244'));
  chaosBox.appendChild(div({style:{color:'#f5a0a8',fontSize:'12px',marginBottom:'3px'}},plan.chaos?.what));
  chaosBox.appendChild(div({style:{color:'#555',fontSize:'11px',fontStyle:'italic'}},plan.chaos?.impact));
  planSurf.appendChild(chaosBox);
  wrap.appendChild(planSurf);
}

// Crisis banner
if(crisis){
  const sc = sevColor(crisis.sev);
  const crisisBox = div({style:{background:`${sc}08`,border:`2px solid ${sc}`,borderRadius:'10px',padding:'14px',marginBottom:'12px',animation:'shakeIn .5s ease'}});
  const crow = div({style:{display:'flex',gap:'12px',alignItems:'flex-start',marginBottom:'8px'}});
  crow.appendChild(span({style:{fontSize:'26px',flexShrink:'0'}},crisis.icon));
  const cinfo = div({});
  cinfo.appendChild(div({style:{color:sc,fontFamily:t.font,fontSize:'13px',letterSpacing:'3px',textTransform:'uppercase',marginBottom:'5px'}},crisis.title));
  cinfo.appendChild(div({style:{color:'#ddd',fontSize:'13px',lineHeight:'1.7'}},crisis.desc));
  crow.appendChild(cinfo);
  crisisBox.appendChild(crow);
  wrap.appendChild(crisisBox);
}

// Last result
if(lastResult) wrap.appendChild(mkCrowdResult(lastResult, t));

// Current step header
const cur = road[step];
const stepSurf = mkSurface(t, {marginBottom:'10px', borderColor:cur?.type==='ppv'?`${t.accent}55`:t.border});
const stepRow = div({style:{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:cur?.type==='ppv'?'10px':'0'}});
const stepLeft = div({cls:'flex-row'});
stepLeft.appendChild(mkTag(cur?.type==='ppv'?'🏆 PPV':'📅 Semaine', cur?.type==='ppv'?t.alt:t.accent));
stepLeft.appendChild(span({style:{color:'#fff',fontFamily:t.font,fontSize:'15px',letterSpacing:'3px',textTransform:'uppercase'}},cur?.label||''));
stepRow.appendChild(stepLeft);
stepRow.appendChild(span({style:{color:'#222',fontSize:'10px',fontFamily:t.font}},`${step+1}/${road.length}`));
stepSurf.appendChild(stepRow);

// PPV stip selector
if(cur?.type==='ppv'){
  if(cur.specialStip){
    const specialBox = div({style:{marginBottom:'10px'}});
    specialBox.appendChild(mkLabel('Match principal imposé',t.alt));
    const sBox = div({style:{background:`${t.alt}0a`,border:`2px solid ${t.alt}44`,borderRadius:'9px',padding:'10px 13px',display:'flex',gap:'10px',alignItems:'center'}});
    sBox.appendChild(span({style:{fontSize:'20px'}},cur.specialStip.icon));
    const sInfo = div({});
    sInfo.appendChild(div({style:{color:t.alt,fontFamily:t.font,fontSize:'13px',letterSpacing:'2px',fontWeight:'700'}},cur.specialStip.label));
    sBox.appendChild(sInfo);
    specialBox.appendChild(sBox);
    stepSurf.appendChild(specialBox);
  }
  stepSurf.appendChild(mkLabel('Stipulation match secondaire'));
  const stipGrid = div({style:{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(118px,1fr))',gap:'5px'}});
  getStips(STATE.promo).forEach(s => {
    const card = div({style:{
      background:ppvStip===s.id?`${t.accent}14`:t.surface,
      border:`1.5px solid ${ppvStip===s.id?t.accent:t.border}`,
