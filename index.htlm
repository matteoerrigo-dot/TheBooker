    // Superstar cell
    const wCell = div({style:{background:t.surface,border:`1px solid ${c}1a`,borderRadius:'8px',padding:'8px 10px',display:'flex',flexDirection:'column',gap:'4px'}});
    wCell.appendChild(div({style:{color:'#ccc',fontFamily:t.font,fontSize:'10px',textTransform:'uppercase'}},w.short+(w.title?' 🏆':'')));
    const bars = div({style:{display:'flex',gap:'3px'}});
