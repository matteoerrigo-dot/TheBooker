function applyTitleChange(prev, titleChange){
if(!titleChange||!titleChange.fromId||!titleChange.toId) return prev;
const from=prev.find(w=>w.id===titleChange.fromId);
if(!from) return prev;
return prev.map(w=>{
if(w.id===titleChange.fromId) return {…w,title:null,mom:Math.max(0,w.mom-10)};
if(w.id===titleChange.toId)   return {…w,title:from.title,mom:Math.min(100,w.mom+15),pop:Math.min(100,w.pop+5)};
return w;
});
}

// ═══════════════════════════════════════════════════════
// MINI UI ENGINE (vanilla JS)
// ═══════════════════════════════════════════════════════

// Global state
let STATE = {
screen: ‘promo’,   // promo | home | mode
promo: ‘WWE’,
difficulty: ‘normal’,
mode: null,        // storyline | road
roster: [],
globalStars: [],
};

function getT(){ return T[STATE.promo]; }

function isMobile(){ return window.innerWidth < 680; }

// ── DOM helpers ──────────────────────────────────────
function el(tag, attrs={}, …children){
const e = document.createElement(tag);
for(const [k,v] of Object.entries(attrs)){
if(k === ‘style’ && typeof v === ‘object’){
Object.assign(e.style, v);
} else if(k.startsWith(‘on’) && typeof v === ‘function’){
e.addEventListener(k.slice(2).toLowerCase(), v);
} else if(k === ‘cls’){
e.className = v;
} else if(k === ‘html’){
e.innerHTML = v;
} else {
e.setAttribute(k, v);
}
}
for(const c of children){
if(c == null) continue;
if(typeof c === ‘string’ || typeof c === ‘number’){
e.appendChild(document.createTextNode(String(c)));
} else if(c instanceof Node){
e.appendChild(c);
}
}
return e;
}

function div(attrs={}, …children){ return el(‘div’, attrs, …children); }
function span(attrs={}, …children){ return el(‘span’, attrs, …children); }
function btn(attrs={}, …children){ return el(‘button’, attrs, …children); }
function inp(attrs={}){ return el(‘input’, attrs); }

function render(node){
const app = document.getElementById(‘app’);
app.innerHTML = ‘’;
app.appendChild(node);
window.scrollTo(0,0);
}

// ── Shared UI components ─────────────────────────────

function mkStars(v=0, size=20, color=’#f5c518’){
const full = Math.floor(v);
const half = v % 1 >= .5;
const empty = 5 - full - (half ? 1 : 0);
const w = div({cls:‘stars-wrap’});
for(let i=0;i<full;i++) w.appendChild(span({style:{fontSize:size+‘px’,color,filter:`drop-shadow(0 0 3px ${color}55)`}},‘★’));
if(half) w.appendChild(span({style:{fontSize:size+‘px’,color,opacity:.5}},‘★’));
for(let i=0;i<empty;i++) w.appendChild(span({style:{fontSize:size+‘px’,color,opacity:.1}},‘★’));
return w;
}

function mkTag(text, color=’#555’){
return span({style:{
background:`${color}18`, border:`1px solid ${color}44`, color,
fontSize:‘9px’, letterSpacing:‘2px’, padding:‘2px 8px’,
borderRadius:‘3px’, fontWeight:‘700’, textTransform:‘uppercase’
}}, text);
}

function mkBtn(text, onClick, opts={}){
const t = opts.t || getT();
const isPrimary = (opts.variant||‘primary’) === ‘primary’;
const disabled = opts.disabled || false;
const small = opts.small || false;
const full = opts.full || false;
const b = btn({
style:{
background: isPrimary ? (disabled ? ‘#1a1a1a’ : `linear-gradient(135deg,${t.accent},${t.alt})`) : ‘transparent’,
border: isPrimary ? ‘none’ : `1px solid ${t.border}`,
color: isPrimary ? (disabled ? ‘#333’ : ‘#000’) : ‘#666’,
fontFamily: t.font, fontSize: small ? ‘11px’ : ‘13px’,
letterSpacing: small ? ‘2px’ : ‘3px’,
padding: small ? ‘8px 14px’ : ‘13px 20px’,
borderRadius: ‘8px’, fontWeight: ‘900’, textTransform: ‘uppercase’,
width: full ? ‘100%’ : ‘auto’, opacity: disabled ? .45 : 1,
transition: ‘all .15s’, flexShrink:‘0’
}
}, text);
if(!disabled) b.addEventListener(‘click’, onClick);
return b;
}

function mkSurface(t, style={}){
return div({style:{
background:t.surface, border:`1px solid ${t.border}`,
borderRadius:‘12px’, padding:‘14px’, …style
}});
}

function mkLabel(text, color){
return div({style:{
color: color||’#333’, fontSize:‘9px’, letterSpacing:‘3px’,
textTransform:‘uppercase’, fontWeight:‘700’, marginBottom:‘8px’
}}, text);
}

function mkMiniBar(label, v, color){
const w = div({style:{flex:‘1’}});
const top = div({style:{display:‘flex’,justifyContent:‘space-between’,marginBottom:‘2px’}});
top.appendChild(span({style:{color:’#2a2a3a’,fontSize:‘8px’}},label));
top.appendChild(span({style:{color,fontSize:‘9px’,fontWeight:‘700’}},v));
const track = div({style:{height:‘2px’,background:’#111’,borderRadius:‘1px’}});
const fill = div({style:{width:`${v}%`,height:‘100%’,background:color,borderRadius:‘1px’}});
track.appendChild(fill); w.appendChild(top); w.appendChild(track);
return w;
}

function mkNavBar(title, onHome, t, extras=[]){
const row = div({style:{
display:‘flex’, alignItems:‘center’, gap:‘8px’,
marginBottom:‘16px’, paddingBottom:‘12px’,
borderBottom:`1px solid ${t.border}`, flexWrap:‘wrap’
}});
row.appendChild(mkBtn(‘← Home’, onHome, {t, variant:‘ghost’, small:true}));
row.appendChild(span({style:{
color:t.accent, fontFamily:t.font, fontSize:‘16px’,
letterSpacing:‘3px’, textTransform:‘uppercase’,
textShadow:`0 0 14px ${t.glow}33`, flexShrink:‘1’,
overflow:‘hidden’, textOverflow:‘ellipsis’, whiteSpace:‘nowrap’
}}, title));
if(extras.length){
const ex = div({style:{marginLeft:‘auto’,display:‘flex’,gap:‘6px’,alignItems:‘center’,flexWrap:‘wrap’}});
extras.forEach(e => ex.appendChild(e));
row.appendChild(ex);
}
return row;
}

function mkPageWrap(t, content){
const page = div({style:{
minHeight:‘100vh’, background:t.bg, position:‘relative’, fontFamily:‘system-ui,sans-serif’
}});
// Background gradient
const bg = div({style:{position:‘fixed’,inset:‘0’,zIndex:‘0’,pointerEvents:‘none’}});
bg.appendChild(div({style:{position:‘absolute’,inset:‘0’,background:t.grad}}));
bg.appendChild(div({style:{position:‘absolute’,inset:‘0’,
backgroundImage:‘repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.12) 2px,rgba(0,0,0,.12) 4px)’,
opacity:’.3’}}));
page.appendChild(bg);
const inner = div({style:{position:‘relative’,zIndex:‘1’}});
inner.appendChild(content);
page.appendChild(inner);
return page;
}

function mkSheet(title, content, onClose, t){
const overlay = div({cls:‘sheet-overlay’});
overlay.addEventListener(‘click’, onClose);
const inner = div({cls:‘sheet-inner’, style:{background:t.bg, border:`1px solid ${t.border}`}});
inner.addEventListener(‘click’, e => e.stopPropagation());
const header = div({cls:‘sheet-header’, style:{borderBottom:`1px solid ${t.border}`}});
header.appendChild(div({cls:‘sheet-handle’}));
if(title){
const hrow = div({style:{display:‘flex’,justifyContent:‘space-between’,alignItems:‘center’,marginTop:‘8px’}});
hrow.appendChild(span({style:{color:t.accent,fontSize:‘13px’,fontFamily:t.font,letterSpacing:‘3px’,textTransform:‘uppercase’}},title));
const xb = btn({style:{background:‘none’,border:`1px solid ${t.border}`,color:’#555’,width:‘26px’,height:‘26px’,borderRadius:‘5px’,fontSize:‘12px’}},‘×’);
xb.addEventListener(‘click’, onClose);
hrow.appendChild(xb);
header.appendChild(hrow);
}
inner.appendChild(header);
const body = div({cls:‘sheet-body’});
body.appendChild(content);
inner.appendChild(body);
overlay.appendChild(inner);
return overlay;
}

// ── CrowdResult display ──────────────────────────────
function mkCrowdResult(result, t){
if(!result) return div({});
const vc = VERDICT_C[result.verdict]||’#888’;
const nl = NOISE_LVL[result.noise]||NOISE_LVL[3];
const wrap = div({style:{
background:t.surface, border:`1px solid ${vc}33`,
borderRadius:‘12px’, overflow:‘hidden’, marginTop:‘12px’,
animation:‘slideUp .4s ease’
}});
// Header
const head = div({style:{
background:`${nl.c}10`, borderBottom:`1px solid ${nl.c}18`,
padding:‘10px 14px’, display:‘flex’, alignItems:‘center’, gap:‘10px’
}});
head.appendChild(span({style:{fontSize:‘20px’}}, nl.emoji));
const hinfo = div({style:{flex:‘1’}});
const bars = div({style:{display:‘flex’,gap:‘2px’,marginBottom:‘3px’}});
for(let n=1;n<=5;n++){
bars.appendChild(div({style:{flex:‘1’,height:‘3px’,borderRadius:‘1px’,background:n<=result.noise?nl.c:’#111’}}));
}
hinfo.appendChild(bars);
hinfo.appendChild(div({style:{color:nl.c,fontSize:‘8px’,letterSpacing:‘2px’,textTransform:‘uppercase’,fontWeight:‘700’}},nl.label));
head.appendChild(hinfo);
head.appendChild(mkTag(result.verdict, vc));
wrap.appendChild(head);
// Body
const body = div({style:{padding:‘14px’}});
const starRow = div({style:{display:‘flex’,alignItems:‘baseline’,gap:‘8px’,marginBottom:‘10px’}});
starRow.appendChild(mkStars(result.stars, 22, t.alt));
starRow.appendChild(span({style:{color:t.alt,fontFamily:t.font,fontSize:‘30px’,lineHeight:‘1’,textShadow:`0 0 10px ${t.alt}44`}},result.stars));
starRow.appendChild(span({style:{color:’#333’,fontSize:‘13px’}},’/5’));
body.appendChild(starRow);
// Chant
const chantBox = div({style:{background:’#ffffff04’,border:`1px solid ${nl.c}15`,borderRadius:‘8px’,padding:‘8px 12px’,marginBottom:‘10px’,textAlign:‘center’}});
chantBox.appendChild(span({style:{color:nl.c,fontFamily:t.font,fontSize:‘13px’,letterSpacing:‘3px’}},`📣 « ${result.chant} »`));
body.appendChild(chantBox);
body.appendChild(div({style:{color:’#aaa’,fontSize:‘13px’,fontStyle:‘italic’,lineHeight:‘1.7’,marginBottom:‘10px’}},`"${result.reaction}"`));
// Voice
const voiceBox = div({style:{borderLeft:`3px solid ${vc}`,paddingLeft:‘12px’,marginBottom:‘10px’}});
voiceBox.appendChild(mkLabel(‘La foule’));
voiceBox.appendChild(div({style:{color:’#666’,fontSize:‘12px’,lineHeight:‘1.7’}},result.voice));
body.appendChild(voiceBox);
// Highlights/Mistakes
if(result.highlights?.length || result.mistakes?.length){
const grid = div({style:{display:‘grid’,gridTemplateColumns:‘1fr 1fr’,gap:‘8px’,marginBottom:‘10px’}});
const hl = div({style:{background:’#00e5aa08’,border:‘1px solid #00e5aa18’,borderRadius:‘8px’,padding:‘10px’}});
hl.appendChild(mkLabel(‘✓ Points forts’,’#00e5aa’));
(result.highlights||[]).forEach(h=>hl.appendChild(div({style:{color:’#88e8cc’,fontSize:‘11px’,lineHeight:‘1.6’}},`· ${h}`)));
grid.appendChild(hl);
const ml = div({style:{background:’#ff224408’,border:‘1px solid #ff224418’,borderRadius:‘8px’,padding:‘10px’}});
ml.appendChild(mkLabel(‘✗ Erreurs’,’#ff2244’));
if(result.mistakes?.length){
result.mistakes.forEach(m=>ml.appendChild(div({style:{color:’#f5a0a8’,fontSize:‘11px’,lineHeight:‘1.6’}},`· ${m}`)));
} else {
ml.appendChild(div({style:{color:’#333’,fontSize:‘11px’}},‘Aucune’));
}
grid.appendChild(ml);
body.appendChild(grid);
}
// Note
const noteBox = div({style:{background:’#00e5aa06’,border:‘1px solid #00e5aa14’,borderRadius:‘8px’,padding:‘10px’}});
noteBox.appendChild(mkLabel(‘📋 Note de booking’,’#00e5aa’));
noteBox.appendChild(div({style:{color:’#88e8cc’,fontSize:‘12px’,lineHeight:‘1.7’}},result.note));
body.appendChild(noteBox);
wrap.appendChild(body);
return wrap;
}

// ── ActionPicker sheet ───────────────────────────────
function mkActionPicker(wrestler, role, onPick, onClose, t, promo){
if(!wrestler) return div({});
const c = rc(role);
const acts = getActs(promo);
const wrap = div({});
const hdr = div({style:{position:‘relative’}});
hdr.appendChild(div({style:{position:‘absolute’,top:‘0’,left:‘0’,right:‘0’,height:‘2px’,background:`linear-gradient(90deg,${c},${t.alt},transparent)`,borderRadius:‘16px 16px 0 0’}}));
const htop = div({style:{display:‘flex’,justifyContent:‘space-between’,alignItems:‘center’,paddingTop:‘4px’}});
const hinfo = div({});
hinfo.appendChild(div({style:{color:c,fontFamily:t.font,fontSize:‘15px’,letterSpacing:‘3px’,textTransform:‘uppercase’}},wrestler.name));
hinfo.appendChild(div({style:{color:’#444’,fontSize:‘10px’}},`Choisir une action · ${role}`));
htop.appendChild(hinfo);
const xb = btn({style:{background:‘none’,border:`1px solid ${t.border}`,color:’#555’,width:‘28px’,height:‘28px’,borderRadius:‘6px’,fontSize:‘13px’}},‘×’);
xb.addEventListener(‘click’, onClose);
htop.appendChild(xb);
hdr.appendChild(htop);
wrap.appendChild(hdr);

CAT_KEYS.forEach(cat => {
const catD = acts[cat];
const catActs = role === ‘heel’ ? catD.heel : catD.face;
const section = div({style:{marginBottom:‘14px’,marginTop:‘12px’}});
const catHeader = div({style:{display:‘flex’,alignItems:‘center’,gap:‘6px’,marginBottom:‘8px’}});
catHeader.appendChild(span({style:{fontSize:‘14px’}},catD.icon));
catHeader.appendChild(span({style:{color:’#444’,fontSize:‘9px’,letterSpacing:‘3px’,textTransform:‘uppercase’,fontFamily:t.font}},catD.label));
section.appendChild(catHeader);
const grid = div({style:{display:‘grid’,gridTemplateColumns:‘repeat(auto-fill,minmax(150px,1fr))’,gap:‘5px’}});
catActs.forEach(action => {
const ab = btn({style:{
background:t.surface, border:`1.5px solid ${t.border}`,
borderRadius:‘8px’, padding:‘9px 10px’, textAlign:‘left’, transition:‘all .12s’
}});
ab.appendChild(div({style:{color:’#ddd’,fontSize:‘11px’,fontWeight:‘700’,marginBottom:‘2px’}},action.label));
if(action.desc) ab.appendChild(div({style:{color:’#444’,fontSize:‘9px’,lineHeight:‘1.4’,marginBottom:‘4px’}},action.desc));
const stats = div({style:{display:‘flex’,gap:‘6px’}});
stats.appendChild(span({style:{color:t.alt,fontSize:‘9px’}},`+${action.mom} MOM`));
stats.appendChild(span({style:{color:’#ff2244’,fontSize:‘9px’}},`+${action.heat} HEAT`));
ab.appendChild(stats);
ab.addEventListener(‘click’, () => onPick(cat, action));
grid.appendChild(ab);
});
section.appendChild(grid);
wrap.appendChild(section);
});
return wrap;
}

// ── RosterPanel ──────────────────────────────────────
function mkRosterList(roster, t, onSelect){
const list = div({style:{display:‘flex’,flexDirection:‘column’,gap:‘3px’}});
roster.forEach(w => {
const c = rc(w.role);
const row = div({style:{
display:‘flex’, alignItems:‘center’, gap:‘7px’,
padding:‘7px 9px’, background:’#ffffff04’,
border:‘1px solid transparent’, borderRadius:‘7px’,
opacity: w.status !== ‘active’ ? .3 : 1, cursor:‘pointer’, transition:‘all .12s’
}});
row.appendChild(div({style:{width:‘3px’,height:‘18px’,borderRadius:‘2px’,background:c,flexShrink:‘0’}}));
const info = div({style:{flex:‘1’,minWidth:‘0’}});
info.appendChild(div({style:{color:’#ddd’,fontSize:‘11px’,fontWeight:‘700’,whiteSpace:‘nowrap’,overflow:‘hidden’,textOverflow:‘ellipsis’,fontFamily:t.font}},w.short));
info.appendChild(div({style:{color:’#333’,fontSize:‘8px’,textTransform:‘uppercase’}},w.tier+(w.status===‘injured’?’ 🚑’:’’)+(w.title?’ 🏆’:’’)));
row.appendChild(info);
row.appendChild(span({style:{color:t.accent,fontSize:‘10px’,fontWeight:‘900’,fontFamily:t.font}},w.mom));
if(onSelect) row.addEventListener(‘click’, () => onSelect(w.id));
list.appendChild(row);
});
return list;
}

// ═══════════════════════════════════════════════════════
// SCREEN: PROMO SELECT
// ═══════════════════════════════════════════════════════
function screenPromo(){
const wrap = div({style:{
minHeight:‘100vh’, background:’#000’, display:‘flex’, flexDirection:‘column’,
alignItems:‘center’, justifyContent:‘center’, padding:‘32px 16px’,
position:‘relative’, overflow:‘hidden’, fontFamily:‘system-ui,sans-serif’
}});
wrap.appendChild(div({style:{position:‘absolute’,inset:‘0’,backgroundImage:‘repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(255,255,255,.012) 2px,rgba(255,255,255,.012) 4px)’}}));
const inner = div({style:{position:‘relative’,zIndex:‘1’,width:‘100%’,maxWidth:‘520px’}});

// Title
const titleWrap = div({style:{textAlign:‘center’,marginBottom:‘32px’}});
titleWrap.appendChild(div({style:{color:’#333’,fontSize:‘9px’,letterSpacing:‘10px’,fontFamily:“Impact,sans-serif”,marginBottom:‘12px’}},‘FANTASY BOOKING’));
const title = div({style:{fontFamily:“Impact,sans-serif”,fontSize:‘clamp(3.5rem,14vw,7rem)’,letterSpacing:‘4px’,lineHeight:’.85’,color:’#fff’,textTransform:‘uppercase’}});
title.appendChild(document.createTextNode(‘THE’));
title.appendChild(el(‘br’));
const outline = span({style:{WebkitTextStroke:‘2px #fff’,WebkitTextFillColor:‘transparent’}},‘BOOKER’);
title.appendChild(outline);
titleWrap.appendChild(title);
titleWrap.appendChild(div({style:{color:’#222’,fontSize:‘10px’,marginTop:‘16px’,letterSpacing:‘4px’}},‘CHOISIS TA PROMOTION’));
inner.appendChild(titleWrap);

// Difficulty
let selectedDiff = ‘normal’;
const diffWrap = div({style:{display:‘flex’,gap:‘8px’,marginBottom:‘20px’,justifyContent:‘center’}});
const diffs = [[‘normal’,‘NORMAL’,‘Accessible’,‘🎮’],[‘hard’,‘HARD’,‘Exigeant’,‘💀’]];
const diffBtns = {};
diffs.forEach(([v,label,desc,icon]) => {
const col = v===‘hard’ ? ‘#ff2244’ : ‘#00e5aa’;
const d = div({style:{
background:’#0a0a0a’, border:`2px solid #1a1a1a`,
borderRadius:‘10px’, padding:‘10px 16px’, cursor:‘pointer’,
textAlign:‘center’, transition:‘all .2s’, minWidth:‘130px’
}});
d.appendChild(div({style:{fontSize:‘16px’,marginBottom:‘3px’}},icon));
d.appendChild(div({style:{color:’#444’,fontFamily:‘Impact,sans-serif’,fontSize:‘12px’,letterSpacing:‘3px’,marginBottom:‘2px’}},label));
d.appendChild(div({style:{color:’#333’,fontSize:‘9px’,lineHeight:‘1.4’}},desc));
const bar = div({style:{width:‘16px’,height:‘2px’,borderRadius:‘1px’,margin:‘6px auto 0’,opacity:‘0’}});
d.appendChild(bar);
d.addEventListener(‘click’, () => {
selectedDiff = v;
diffs.forEach(([dv]) => {
const dc = v===‘hard’?’#ff2244’:’#00e5aa’;
const isSelected = dv === v;
const dcol = dv===‘hard’?’#ff2244’:’#00e5aa’;
diffBtns[dv].style.background = isSelected ? `${dcol}12` : ‘#0a0a0a’;
diffBtns[dv].style.borderColor = isSelected ? dcol : ‘#1a1a1a’;
diffBtns[dv].querySelector(’.diff-bar’).style.opacity = isSelected ? ‘1’ : ‘0’;
diffBtns[dv].querySelector(’.diff-bar’).style.background = dcol;
diffBtns[dv].querySelector(’.diff-label’).style.color = isSelected ? dcol : ‘#444’;
});
});
diffBtns[v] = d;
const barEl = d.querySelector(‘div:last-child’);
barEl.className = ‘diff-bar’;
d.querySelectorAll(‘div’)[1].className = ‘diff-label’;
diffWrap.appendChild(d);
});
// Set initial state for normal
diffBtns[‘normal’].style.background = ‘#00e5aa12’;
diffBtns[‘normal’].style.borderColor = ‘#00e5aa’;
diffBtns[‘normal’].querySelector(’.diff-bar’).style.opacity = ‘1’;
diffBtns[‘normal’].querySelector(’.diff-bar’).style.background = ‘#00e5aa’;
diffBtns[‘normal’].querySelector(’.diff-label’).style.color = ‘#00e5aa’;
inner.appendChild(diffWrap);

// Promo cards
const grid = div({style:{display:‘grid’,gridTemplateColumns:‘1fr 1fr’,gap:‘12px’}});
Object.values(T).forEach(p => {
const card = div({style:{
background:’#0a0a0a’, border:‘2px solid #1a1a1a’,
borderRadius:‘14px’, padding:‘26px 18px’, cursor:‘pointer’,
textAlign:‘center’, transition:‘all .2s’, position:‘relative’, overflow:‘hidden’
}});
// Corner triangle
card.appendChild(div({style:{position:‘absolute’,top:‘0’,left:‘0’,width:‘0’,height:‘0’,borderStyle:‘solid’,borderWidth:‘26px 26px 0 0’,borderColor:`${p.accent} transparent transparent transparent`}}));
card.appendChild(div({style:{fontFamily:p.font,fontSize:‘clamp(2rem,9vw,3.5rem)’,fontWeight:‘900’,letterSpacing:‘4px’,color:p.accent,textShadow:`0 0 20px ${p.glow}55`,lineHeight:‘1’,marginBottom:‘8px’,textTransform:‘uppercase’}},p.badge));
card.appendChild(div({style:{color:’#444’,fontSize:‘9px’,letterSpacing:‘3px’,marginBottom:‘14px’}},p.tagline));
card.appendChild(div({style:{color:’#333’,fontSize:‘10px’,marginBottom:‘14px’}},`${ROSTERS[p.id].length} superstars · ${ROSTERS[p.id].filter(w=>w.title).length} champions`));
const pill = div({style:{background:`${p.accent}16`,border:`1px solid ${p.accent}44`,borderRadius:‘7px’,padding:‘7px 12px’,color:p.accent,fontFamily:p.font,fontSize:‘11px’,letterSpacing:‘3px’,textTransform:‘uppercase’}},‘SÉLECTIONNER’);
card.appendChild(pill);
card.addEventListener(‘mouseenter’, () => { card.style.borderColor = p.accent; pill.textContent = ‘ENTRER →’; card.style.transform=‘scale(1.02)’; });
card.addEventListener(‘mouseleave’, () => { card.style.borderColor = ‘#1a1a1a’; pill.textContent = ‘SÉLECTIONNER’; card.style.transform=‘scale(1)’; });
card.addEventListener(‘click’, () => {
STATE.promo = p.id;
STATE.difficulty = selectedDiff;
STATE.roster = JSON.parse(JSON.stringify(ROSTERS[p.id]));
STATE.globalStars = [];
render(screenHome());
});
grid.appendChild(card);
});
inner.appendChild(grid);
wrap.appendChild(inner);
return wrap;
}

// ═══════════════════════════════════════════════════════
// SCREEN: HOME
// ═══════════════════════════════════════════════════════
function screenHome(){
const t = getT();
const page = mkPageWrap(t, (() => {
const wrap = div({style:{maxWidth:‘860px’,margin:‘0 auto’,padding:‘24px 14px 60px’}});
// Header
const header = div({style:{display:‘flex’,justifyContent:‘space-between’,alignItems:‘flex-start’,marginBottom:‘30px’,flexWrap:‘wrap’,gap:‘12px’}});
const left = div({});
left.appendChild(mkTag(t.badge, t.accent));
left.appendChild(div({style:{fontFamily:t.font,fontSize:‘clamp(2rem,8vw,4rem)’,letterSpacing:‘4px’,lineHeight:’.85’,color:’#fff’,textTransform:‘uppercase’,marginTop:‘10px’,textShadow:`0 0 20px ${t.glow}22`}},‘THE’));

```
left.lastChild.appendChild(span({style:{color:t.accent}},'BOOKER'));
left.appendChild(div({style:{color:'#222',fontSize:'9px',marginTop:'8px',letterSpacing:'5px',fontFamily:t.font}},t.tagline));
header.appendChild(left);

const right = div({style:{display:'flex',flexDirection:'column',gap:'8px',alignItems:'flex-end'}});
const avg = STATE.globalStars.length ? (STATE.globalStars.reduce((a,b)=>a+b,0)/STATE.globalStars.length).toFixed(1) : null;
if(avg){
  const surf = mkSurface(t, {padding:'10px 14px',textAlign:'center'});
  surf.appendChild(mkLabel('Ton show'));
  surf.appendChild(mkStars(parseFloat(avg),15,t.alt));
  surf.appendChild(div({style:{color:t.alt,fontFamily:t.font,fontSize:'24px',lineHeight:'1',marginTop:'3px'}},avg+'/5'));
  right.appendChild(surf);
}
right.appendChild(mkBtn('Changer de promo', () => render(screenPromo()), {t, variant:'ghost', small:true}));
const diffBadge = div({style:{
  background: STATE.difficulty==='hard'?'#ff224412':'#00e5aa12',
  border: `1px solid ${STATE.difficulty==='hard'?'#ff244433':'#00e5aa33'}`,
  borderRadius:'6px', padding:'4px 10px', textAlign:'center'
}});
diffBadge.appendChild(div({style:{color:STATE.difficulty==='hard'?'#ff2244':'#00e5aa',fontFamily:t.font,fontSize:'9px',letterSpacing:'3px'}},STATE.difficulty==='hard'?'💀 HARD':'🎮 NORMAL'));
right.appendChild(diffBadge);
header.appendChild(right);
wrap.appendChild(header);

// Mode cards
const modes = [
  {key:'storyline',icon:'🧵',title:'Storyline',c:t.accent},
  {key:'career',icon:'🎭',title:'Carrière (bientôt)',c:t.alt,disabled:true},
  {key:'road',icon:'🎲',title:'Road to PPV',c:'#f5c518'},
];
const modeGrid = div({style:{display:'grid',gridTemplateColumns:'repeat(auto-fit,minmax(200px,1fr))',gap:'10px',marginBottom:'24px'}});
modes.forEach(m => {
  const card = div({style:{
    background:t.surface, border:`1.5px solid ${t.border}`,
    borderRadius:'12px', padding:'18px 14px', cursor: m.disabled?'not-allowed':'pointer',
    transition:'all .18s', position:'relative', overflow:'hidden', opacity: m.disabled?.5:1
  }});
  card.appendChild(div({style:{position:'absolute',top:'0',left:'0',right:'0',height:'2px',background:'transparent',transition:'all .25s'}}));
  card.appendChild(div({style:{fontSize:'24px',marginBottom:'8px'}},m.icon));
  card.appendChild(div({style:{color:m.c,fontFamily:t.font,fontSize:'13px',letterSpacing:'3px',marginBottom:'5px',textTransform:'uppercase'}},m.title));
  const go = div({style:{color:'#2a2a3a',fontSize:'9px',letterSpacing:'2px',fontFamily:t.font,transition:'color .15s'}},'JOUER');
  card.appendChild(go);
  if(!m.disabled){
    card.addEventListener('mouseenter', () => {
      card.style.borderColor = m.c; card.style.transform='translateY(-2px)';
      card.querySelector('div:first-child').style.background = `linear-gradient(90deg,transparent,${m.c},transparent)`;
      go.style.color = m.c; go.textContent = 'JOUER →';
    });
    card.addEventListener('mouseleave', () => {
      card.style.borderColor = t.border; card.style.transform='none';
      card.querySelector('div:first-child').style.background = 'transparent';
      go.style.color = '#2a2a3a'; go.textContent = 'JOUER';
    });
    card.addEventListener('click', () => {
      STATE.mode = m.key;
      if(m.key === 'storyline') render(screenStoryline());
      else if(m.key === 'road') render(screenRoad());
    });
  }
  modeGrid.appendChild(card);
});
wrap.appendChild(modeGrid);

// Roster preview
const rosterSurf = mkSurface(t, {padding:'10px'});
rosterSurf.appendChild(mkLabel(`Roster — ${t.badge}`, t.accent));
const rosterPills = div({cls:'flex-wrap'});
STATE.roster.forEach(w => {
  const pill = div({style:{background:'#ffffff05',border:`1px solid ${rc(w.role)}18`,borderRadius:'6px',padding:'4px 9px',display:'flex',alignItems:'center',gap:'4px'}});
  pill.appendChild(div({style:{width:'3px',height:'3px',borderRadius:'50%',background:rc(w.role)}}));
  pill.appendChild(span({style:{color:'#666',fontSize:'11px',fontFamily:t.font}},w.short));
  if(w.title) pill.appendChild(span({style:{fontSize:'8px'}},'🏆'));
  rosterPills.appendChild(pill);
});
rosterSurf.appendChild(rosterPills);
wrap.appendChild(rosterSurf);
return wrap;
```

})());
return page;
}

// ═══════════════════════════════════════════════════════
// SCREEN: STORYLINE MODE
// ═══════════════════════════════════════════════════════
function screenStoryline(){
const t = getT();
const roster = STATE.roster;

// Storyline state
let step = 0;
let selected = [];
let stip = null;
let winner = null;
let titleChange = null;
let matchFormat = {format:‘singles’, participants:[], winnerId:null};
let weeks = [{},{},{},{}]; // {wid: {cat, action}}
let result = null;
let loading = false;

function goHome(){ render(screenHome()); }

function rebuild(){
render(mkPageWrap(t, buildUI()));
}

function buildUI(){
const wrap = div({style:{maxWidth:‘860px’,margin:‘0 auto’,padding:‘20px 14px 100px safe-bottom’}});
wrap.appendChild(mkNavBar(‘🧵 Storyline’, goHome, t));

```
if(step === 0) wrap.appendChild(buildStep0());
else if(step === 1) wrap.appendChild(buildStep1());
else if(step === 2) wrap.appendChild(buildStep2());

return wrap;
```

}

// ── Step 0: Setup ──
function buildStep0(){
const frag = div({});
// Wrestler selection
const surf = mkSurface(t, {marginBottom:‘10px’});
surf.appendChild(mkLabel(‘Acteurs (2 à 6)’, t.accent));
const grid = div({style:{display:‘grid’,gridTemplateColumns:‘repeat(auto-fill,minmax(130px,1fr))’,gap:‘6px’}});
roster.forEach(w => {
const isSel = selected.includes(w.id);
const c = rc(w.role);
const card = div({style:{
background: isSel?`${c}14`:t.surface,
border:`1.5px solid ${isSel?c:t.border}`,
borderRadius:‘8px’, padding:‘9px 10px’, cursor:‘pointer’,
transition:‘all .12s’, opacity:(!isSel&&selected.length>=6)?.35:1
}});
const top = div({style:{display:‘flex’,justifyContent:‘space-between’,marginBottom:‘3px’}});
top.appendChild(span({style:{color:isSel?c:’#ddd’,fontFamily:t.font,fontSize:‘11px’,fontWeight:‘700’,textTransform:‘uppercase’}},w.short));
if(isSel) top.appendChild(span({style:{color:c,fontSize:‘12px’}},‘✓’));
card.appendChild(top);
card.appendChild(mkTag(w.role, c));
card.addEventListener(‘click’, () => {
if(selected.includes(w.id)) selected = selected.filter(x=>x!==w.id);
else if(selected.length < 6) selected.push(w.id);
rebuild();
});
grid.appendChild(card);
});
surf.appendChild(grid);
surf.appendChild(div({style:{color:’#444’,fontSize:‘10px’,marginTop:‘8px’}},`${selected.length}/6 sélectionnés`));
frag.appendChild(surf);

```
if(selected.length >= 2){
  const selW = roster.filter(w => selected.includes(w.id));

  // Stip
  const stipSurf = mkSurface(t, {marginBottom:'10px'});
  stipSurf.appendChild(mkLabel('Stipulation PPV final', t.accent));
  const stipGrid = div({style:{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(138px,1fr))',gap:'5px'}});
  getStips(STATE.promo).forEach(s => {
    const card = div({style:{
      background:stip===s.id?`${t.accent}14`:t.surface,
      border:`1.5px solid ${stip===s.id?t.accent:t.border}`,
      borderRadius:'8px', padding:'8px 10px', cursor:'pointer',
      display:'flex', alignItems:'center', gap:'7px', transition:'all .12s'
    }});
    card.appendChild(span({style:{fontSize:'13px'}},s.icon));
    card.appendChild(span({style:{color:stip===s.id?t.accent:'#bbb',fontSize:'11px',fontWeight:'700'}},s.label));
    card.addEventListener('click', () => { stip=s.id; rebuild(); });
    stipGrid.appendChild(card);
  });
  stipSurf.appendChild(stipGrid);
  frag.appendChild(stipSurf);

  if(stip){
    // Winner
    const winnerSurf = mkSurface(t, {marginBottom:'12px'});
    winnerSurf.appendChild(mkLabel('Vainqueur', t.accent));
    const winnerRow = div({cls:'flex-wrap'});
    selW.forEach(w => {
      const c = rc(w.role);
      const card = div({style:{
        background:winner===w.id?`${c}14`:t.surface,
        border:`1.5px solid ${winner===w.id?c:t.border}`,
        borderRadius:'8px', padding:'8px 12px', cursor:'pointer',
        display:'flex', alignItems:'center', gap:'6px', transition:'all .12s'
      }});
      card.appendChild(div({style:{width:'5px',height:'5px',borderRadius:'50%',background:c}}));
      card.appendChild(span({style:{color:winner===w.id?c:'#ccc',fontFamily:t.font,fontSize:'12px',textTransform:'uppercase'}},w.name));
      if(winner===w.id) card.appendChild(span({style:{color:c}},'✓'));
      card.addEventListener('click', () => { winner=w.id; rebuild(); });
      winnerRow.appendChild(card);
    });
    winnerSurf.appendChild(winnerRow);
    frag.appendChild(winnerSurf);

    if(winner){
      // Match format
      frag.appendChild(buildMatchFormatPanel(selW));
      // Title change
      frag.appendChild(buildTitleChangePanel());
      // Next step button
      frag.appendChild(mkBtn('Planifier les 4 semaines →', () => { step=1; rebuild(); }, {t, full:true}));
    }
  }
}
return frag;
```

}

// ── Step 1: Week planning ──
function buildStep1(){
const frag = div({});
const selW = roster.filter(w => selected.includes(w.id));

