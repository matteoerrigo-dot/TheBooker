<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>The Booker</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:#000;overscroll-behavior:none;-webkit-font-smoothing:antialiased}
input,textarea,select{font-size:16px!important}
button{touch-action:manipulation;cursor:pointer;border:none;background:none;font-family:inherit}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:#c8102e;border-radius:3px}
@font-face{font-family:'Anton';font-style:normal;font-weight:400;src:local('Anton'),local('Anton-Regular')}

/* Animations */
@keyframes slideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:.4}50%{opacity:1}}
@keyframes bounce{from{transform:translateY(0)}to{transform:translateY(-6px)}}
@keyframes shakeIn{0%{transform:translateX(-8px)}25%{transform:translateX(8px)}50%{transform:translateX(-4px)}75%{transform:translateX(4px)}100%{transform:translateX(0)}}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes glow{0%,100%{opacity:.5}50%{opacity:1}}

.slide-up{animation:slideUp .35s ease forwards}
.shake{animation:shakeIn .5s ease}
.fade-in{animation:fadeIn .3s ease}

#app{min-height:100vh}

/* Sheet overlay */
.sheet-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.8);display:flex;align-items:flex-end;justify-content:center}
.sheet-inner{background:#000;border:1px solid #222;border-radius:16px 16px 0 0;width:100%;max-width:560px;max-height:88vh;overflow-y:auto;animation:slideUp .3s ease}
.sheet-handle{width:36px;height:4px;background:#333;border-radius:2px;margin:12px auto 0}
.sheet-header{position:sticky;top:0;z-index:10;padding:8px 16px 12px}
.sheet-body{padding:14px}

/* Bottom FAB area */
.fab-roster{position:fixed;bottom:20px;right:16px;z-index:80;width:52px;height:52px;border-radius:50%;font-size:20px;box-shadow:0 4px 20px rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center}

/* Timeline scrollable */
.timeline-wrap{overflow-x:auto;padding-bottom:8px;margin-bottom:14px;-webkit-overflow-scrolling:touch}
.timeline{display:flex;gap:3px;min-width:max-content}

/* Grid helpers */
.grid-auto{display:grid;gap:6px}
.flex-wrap{display:flex;flex-wrap:wrap;gap:6px}
.flex-row{display:flex;align-items:center;gap:8px}

/* Action grid desktop */
.action-grid-header{display:grid;grid-template-columns:150px 1fr 80px;gap:6px;margin-bottom:6px}
.action-grid-row{display:grid;grid-template-columns:150px 1fr 80px;gap:6px;margin-bottom:5px;align-items:stretch}

/* Stars */
.stars-wrap{display:inline-flex;gap:1px;line-height:1}

/* Loading dots */
.dots-wrap{display:flex;justify-content:center;gap:5px;margin-top:10px}
.dot{width:5px;height:5px;border-radius:50%;animation:bounce .7s infinite alternate}
.dot:nth-child(2){animation-delay:.15s}
.dot:nth-child(3){animation-delay:.3s}

/* Safe area */
.safe-bottom{padding-bottom:env(safe-area-inset-bottom,16px)}
</style>

</head>
<body>
<div id="app"></div>
<script>
'use strict';

