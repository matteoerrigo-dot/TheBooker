    row.appendChild(wCell);
    // Action cell
    if(entry.action){
      const aCell = div({style:{background:`${c}0a`,border:`1.5px solid ${c}33`,borderRadius:'8px',padding:'8px 10px',cursor:'pointer',minHeight:'70px'}});
      aCell.appendChild(span({style:{fontSize:'13px'}},getActs(STATE.promo)[entry.action.cat]?.icon||''));
      aCell.appendChild(div({style:{color:c,fontSize:'11px',fontWeight:'700',marginTop:'3px'}},entry.action.action.label));
      aCell.addEventListener('click', () => showActionPicker(entry.wid));
      row.appendChild(aCell);
    } else {
      const addBtn = btn({style:{background:t.surface,border:`1px dashed ${t.border}`,borderRadius:'8px',minHeight:'70px',width:'100%',color:'#222',fontSize:'18px'}},'+');
      addBtn.addEventListener('click', () => showActionPicker(entry.wid));
      row.appendChild(addBtn);
    }
    // Role cell
    const roleCell = div({style:{display:'flex',flexDirection:'column',gap:'3px',justifyContent:'center'}});
    ['face','heel','tweener'].forEach(r => {
      const rb = btn({style:{flex:'1',padding:'3px 4px',fontSize:'7px',textTransform:'uppercase',background:entry.role===r?`${rc(r)}14`:'none',border:`1px solid ${entry.role===r?rc(r):t.border}`,color:entry.role===r?rc(r):'#2a2a3a',borderRadius:'3px',fontFamily:t.font}},r);
      rb.addEventListener('click', () => {
        weekPlan=weekPlan.map(e=>e.wid===entry.wid?{...e,role:r}:e);
        STATE.roster=STATE.roster.map(wr=>wr.id===entry.wid?{...wr,role:r}:wr);
        rebuild();
      });
      roleCell.appendChild(rb);
    });
    row.appendChild(roleCell);
    wrap.appendChild(row);
  });
}

// Title change + Submit
wrap.appendChild(buildTitleChangePanel());
wrap.appendChild(div({style:{marginTop:'12px'}}));
wrap.lastChild.appendChild(mkBtn(loading?'⏳ La foule réagit…':`📣 Soumettre — ${cur?.label}`, doSubmitWeek, {t, full:true, disabled:loading}));
return wrap;

function buildTitleChangePanel(){
  const surf = mkSurface(t, {marginBottom:'10px'});
  const enabled = titleChange !== null;
  const champions = STATE.roster.filter(w=>w.title&&w.status==='active');
  const row = div({style:{display:'flex',alignItems:'center',justifyContent:'space-between'}});
  const left = div({style:{display:'flex',alignItems:'center',gap:'8px'}});
  left.appendChild(span({style:{fontSize:'18px'}},'🏆'));
  const linfo = div({});
  linfo.appendChild(div({style:{color:t.alt,fontFamily:t.font,fontSize:'11px',letterSpacing:'2px',textTransform:'uppercase'}},'Changement de titre'));
  left.appendChild(linfo);
  row.appendChild(left);
  const toggleBtn = btn({style:{background:enabled?`${t.alt}18`:'none',border:`1.5px solid ${enabled?t.alt:t.border}`,color:enabled?t.alt:'#444',borderRadius:'20px',padding:'5px 14px',fontSize:'11px',fontFamily:t.font,fontWeight:'700'}},enabled?'OUI':'NON');
  toggleBtn.addEventListener('click', () => {
    titleChange = enabled ? null : {fromId:champions[0]?.id||null,toId:null};
    rebuild();
  });
  row.appendChild(toggleBtn);
  surf.appendChild(row);
  return surf;
}
```

}

function buildIntro(){
const wrap = div({style:{maxWidth:‘620px’,margin:‘0 auto’,padding:‘32px 14px’,textAlign:‘center’}});
wrap.appendChild(mkNavBar(`🎲 Road to ${finalPPV}`, goHome, t));
wrap.appendChild(div({style:{fontFamily:t.font,fontSize:‘clamp(1.8rem,7vw,3.5rem)’,color:t.alt,letterSpacing:‘5px’,lineHeight:’.85’,marginBottom:‘20px’,textTransform:‘uppercase’,textShadow:`0 0 20px ${t.alt}33`}},`ROAD TO ${finalPPV}`));
const surf = mkSurface(t, {textAlign:‘left’,marginBottom:‘20px’});
[{i:‘🤖’,tx:“L’IA génère un plan : vainqueur, feuds, card finale.”},{i:‘💥’,tx:“Elle déclenche une crise qui brise son propre plan.”},{i:‘📅’,tx:“Tu books chaque semaine avec la grille d’actions.”},{i:‘🎲’,tx:“Des crises aléatoires surgissent. Adapte-toi.”},{i:‘📣’,tx:`La foule note chaque étape jusqu'à ${finalPPV}.`}].forEach(({i,tx}) => {
const row = div({style:{display:‘flex’,gap:‘10px’,alignItems:‘flex-start’,marginBottom:‘8px’}});
row.appendChild(span({style:{fontSize:‘16px’,flexShrink:‘0’}},i));
row.appendChild(div({style:{color:’#666’,fontSize:‘12px’,lineHeight:‘1.6’}},tx));
surf.appendChild(row);
});
wrap.appendChild(surf);
wrap.appendChild(mkBtn(‘🎲 Lancer le chaos’, doStart, {t}));
return wrap;
}

function buildGen(){
const wrap = div({style:{textAlign:‘center’,padding:‘100px 20px’}});
wrap.appendChild(div({style:{fontSize:‘44px’,animation:‘spin 2s linear infinite’,marginBottom:‘14px’}},‘⚙️’));
wrap.appendChild(div({style:{color:t.accent,fontFamily:t.font,fontSize:‘17px’,letterSpacing:‘4px’,textTransform:‘uppercase’}},“L’IA construit son plan…”));
return wrap;
}

function buildFinal(){
const avg = weekResults.length ? (weekResults.reduce((s,r)=>s+r.stars,0)/weekResults.length).toFixed(1) : ‘0’;
const wrap = div({style:{maxWidth:‘680px’,margin:‘0 auto’,padding:‘26px 14px 80px’}});
wrap.appendChild(mkNavBar(`🏆 Bilan — ${finalPPV}`, goHome, t));
const scoreWrap = div({style:{textAlign:‘center’,marginBottom:‘20px’}});
scoreWrap.appendChild(div({style:{color:t.alt,fontFamily:t.font,fontSize:‘clamp(3rem,11vw,5rem)’,lineHeight:‘1’,textShadow:`0 0 20px ${t.alt}44`}},avg));
scoreWrap.appendChild(div({style:{color:’#444’,fontSize:‘12px’,fontFamily:t.font,marginBottom:‘6px’}},`/ 5 — ROAD TO ${finalPPV.toUpperCase()}`));
scoreWrap.appendChild(mkStars(parseFloat(avg)||0,22,t.alt));
wrap.appendChild(scoreWrap);
if(plan){
const planSurf = mkSurface(t, {marginBottom:‘12px’});
planSurf.appendChild(mkLabel(‘Le plan secret du booking’,t.accent));
planSurf.appendChild(div({style:{color:’#666’,fontSize:‘12px’,lineHeight:‘1.7’,marginBottom:‘8px’}},plan.narrative));
const chaosBox = div({style:{background:’#ff224408’,border:‘1px solid #ff224418’,borderRadius:‘8px’,padding:‘10px’}});
chaosBox.appendChild(mkLabel(‘💥 Crise initiale’,’#ff2244’));
chaosBox.appendChild(div({style:{color:’#f5a0a8’,fontSize:‘12px’}},plan.chaos?.what));
planSurf.appendChild(chaosBox);
wrap.appendChild(planSurf);
}
const resultsList = div({style:{display:‘flex’,flexDirection:‘column’,gap:‘4px’,marginBottom:‘14px’}});
weekResults.forEach(r => {
const row = div({style:{background:t.surface,border:`1px solid ${r.stars>=4?'#00e5aa':r.stars>=3?'#f5c518':'#ff2244'}18`,borderRadius:‘8px’,padding:‘8px 12px’,display:‘flex’,gap:‘10px’,alignItems:‘center’}});
row.appendChild(div({style:{color:’#444’,fontSize:‘11px’,minWidth:‘100px’,fontFamily:t.font}},r._label||’’));
row.appendChild(mkStars(r.stars,10,t.alt));
row.appendChild(div({style:{color:’#444’,fontSize:‘10px’,flex:‘1’}},r.verdict));
resultsList.appendChild(row);
});
wrap.appendChild(resultsList);
wrap.appendChild(mkBtn(‘🔁 Nouvelle Route’, doRestart, {t, full:true}));
return wrap;
}

return mkPageWrap(t, buildUI());
}

// ═══════════════════════════════════════════════════════
// BOOT
// ═══════════════════════════════════════════════════════
render(screenPromo());
</script>

</body>
</html>
